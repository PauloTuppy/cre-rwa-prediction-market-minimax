# .env.example para apps/frontend

# --- DATABASE ---
# URL do seu banco PostgreSQL (Supabase, Railway, Local)
DATABASE_URL="postgresql://user:password@localhost:5432/rwa_db?schema=public"

# --- SECURITY ---
# Gere um UUID: node -e "console.log(require('crypto').randomUUID())"
API_SECRET="your-uuid-api-secret-here"

# Gere uma chave Hex: openssl rand -hex 32
# Deve ser a mesma chave enviada no header 'x-webhook-secret' pelo CRE Workflow
WEBHOOK_SECRET="your-hex-32-webhook-secret-here"

# --- LLM ORACLE (ORCHESTRATION) ---
MINIMAX_API_KEY="sk-api-..."
MINIMAX_API_URL="https://api.minimax.chat/v1/chat"

# --- NETWORK / CORS ---
# '*' para desenvolvimento ou 'https://seu-dominio.com' para prod
CORS_ALLOWED_ORIGIN="*"

# --- BLOCKCHAIN ---
# Endereço do mercado para referência no frontend
NEXT_PUBLIC_MARKET_ADDRESS="0x..."
CHAIN_ID="11155111" # Sepolia
