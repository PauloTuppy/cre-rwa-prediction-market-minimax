{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "node",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@chainlink/cre-sdk": [
                "./.cre-types/index.d.ts"
            ]
        }
    },
    "include": [
        "**/*.ts"
    ]
}